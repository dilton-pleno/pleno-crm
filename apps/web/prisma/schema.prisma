generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICAÇÃO
// ============================================================

enum Role {
  ADMIN
  GESTOR
  ATENDENTE
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(ATENDENTE)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  assignedConversations Conversation[] @relation("AssignedTo")
  sentMessages          Message[]      @relation("SentBy")
  pipelineCards         PipelineCard[] @relation("CardAssignedTo")
  pipelines             Pipeline[]     @relation("CreatedBy")
  alerts                Alert[]        @relation("CreatedBy")
  automations           Automation[]   @relation("CreatedBy")

  integrationRequestsMade     IntegrationRequest[] @relation("RequestedBy")
  integrationRequestsApproved IntegrationRequest[] @relation("ApprovedBy")

  @@map("users")
}

model IntegrationRequest {
  id          String   @id @default(uuid())
  type        String // "whatsapp_reconnect"
  requestedBy String   @map("requested_by")
  approvedBy  String?  @map("approved_by")
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requester User  @relation("RequestedBy", fields: [requestedBy], references: [id])
  approver  User? @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@map("integration_requests")
}

// Configuração de integrações externas gerenciadas pelo painel (ex.: Wbuy).
// O segredo da API é guardado cifrado (AES-256-GCM) em apiSecret.
model IntegrationConfig {
  id         String   @id @default(uuid())
  provider   String   @unique // "wbuy"
  apiUser    String?  @map("api_user")
  apiSecret  String?  @map("api_secret") // cifrado
  active     Boolean  @default(false)
  config     Json? // metadados (ex.: webhooks registrados)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("integration_configs")
}

// Carrinhos abandonados recebidos via webhook da Wbuy (não há GET na API, logo
// só há dados a partir do recebimento — sem backfill). Base para relatório.
model AbandonedCart {
  id            String   @id @default(uuid())
  externalId    String   @unique @map("external_id") // id_envio
  customerName  String?  @map("customer_name")
  customerEmail String?  @map("customer_email")
  customerPhone String?  @map("customer_phone")
  total         Decimal  @default(0) @db.Decimal(12, 2)
  itemsCount    Int      @default(0) @map("items_count")
  products      Json?
  recovered     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("abandoned_carts")
}

// Produtos ATIVOS da Wbuy (catálogo enxuto p/ cruzar vendas por SKU + SEO).
model WbuyProduct {
  id          String   @id @default(uuid())
  externalId  String   @unique @map("external_id") // id do produto na Wbuy
  cod         String?
  name        String
  description String?  @db.Text
  brand       String?
  category    String?
  categoryUrl String?  @map("category_url")
  gtin        String?
  ncm         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  stock       Int      @default(0)
  views       Int      @default(0)
  active      Boolean  @default(true)
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@map("wbuy_products")
}

// Avaliações de produtos (Wbuy não tem webhook de avaliação → polling).
model WbuyReview {
  id           String    @id @default(uuid())
  externalId   String    @unique @map("external_id")
  productId    String?   @map("product_id")
  productName  String?   @map("product_name")
  customerName String?   @map("customer_name")
  rating       Int       @default(0)
  comment      String?   @db.Text
  approved     Boolean   @default(false)
  reviewDate   DateTime? @map("review_date")
  alertedAt    DateTime? @map("alerted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("wbuy_reviews")
}

// Inscritos na newsletter da Wbuy (chave = email).
model NewsletterSubscriber {
  id         String    @id @default(uuid())
  email      String    @unique
  name       String?
  phone      String?
  gender     String?
  subscribed Boolean   @default(true)
  signupDate DateTime? @map("signup_date")
  syncedAt   DateTime  @default(now()) @map("synced_at")

  @@map("newsletter_subscribers")
}

// ============================================================
// CONTATOS E CANAIS
// ============================================================

enum ChannelType {
  whatsapp
  instagram
  messenger
  email
  site
}

model Contact {
  id             String    @id @default(uuid())
  name           String
  email          String?
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  notes          String?
  organizationId String?   @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  channels      ContactChannel[]
  conversations Conversation[]
  cards         PipelineCard[]
  orders        Order[]

  @@map("contacts")
}

model ContactChannel {
  id                String      @id @default(uuid())
  contactId         String      @map("contact_id")
  channelType       ChannelType @map("channel_type")
  channelIdentifier String      @map("channel_identifier")
  metadata          Json?
  createdAt         DateTime    @default(now()) @map("created_at")

  contact       Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([channelType, channelIdentifier])
  @@map("contact_channels")
}

// ============================================================
// CONVERSAS E MENSAGENS
// ============================================================

enum ConversationStatus {
  open
  pending
  resolved
}

model Conversation {
  id         String             @id @default(uuid())
  contactId  String             @map("contact_id")
  channelId  String             @map("channel_id")
  status     ConversationStatus @default(open)
  assignedTo String?            @map("assigned_to")
  inboxName  String?            @map("inbox_name")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  contact  Contact        @relation(fields: [contactId], references: [id])
  channel  ContactChannel @relation(fields: [channelId], references: [id])
  agent    User?          @relation("AssignedTo", fields: [assignedTo], references: [id])
  messages Message[]
  cards    PipelineCard[]

  @@map("conversations")
}

enum MessageDirection {
  in
  out
}

enum MediaType {
  image
  audio
  document
  sticker
  video
}

model Message {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  direction      MessageDirection
  content        String?
  mediaUrl       String?          @map("media_url")
  mediaType      MediaType?       @map("media_type")
  mediaData      Bytes?           @map("media_data")
  mediaMimeType  String?          @map("media_mime_type")
  mediaFileName  String?          @map("media_file_name")
  externalId     String?          @map("external_id")
  senderId       String?          @map("sender_id")
  sentAt         DateTime         @default(now()) @map("sent_at")
  deliveredAt    DateTime?        @map("delivered_at")
  readAt         DateTime?        @map("read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("SentBy", fields: [senderId], references: [id])

  @@map("messages")
}

// ============================================================
// KANBAN
// ============================================================

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator User            @relation("CreatedBy", fields: [createdBy], references: [id])
  stages  PipelineStage[]

  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String   @map("pipeline_id")
  name       String
  position   Int
  color      String   @default("#6366f1")
  createdAt  DateTime @default(now()) @map("created_at")

  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  cards    PipelineCard[]

  @@map("pipeline_stages")
}

model PipelineCard {
  id             String   @id @default(uuid())
  stageId        String   @map("stage_id")
  conversationId String   @map("conversation_id")
  contactId      String   @map("contact_id")
  assignedTo     String?  @map("assigned_to")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  stage        PipelineStage @relation(fields: [stageId], references: [id])
  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id])
  agent        User?         @relation("CardAssignedTo", fields: [assignedTo], references: [id])

  @@map("pipeline_cards")
}

// ============================================================
// CAMPANHAS E ANALYTICS
// ============================================================

enum AdPlatform {
  meta
  google
}

model CampaignMetric {
  id           String     @id @default(uuid())
  platform     AdPlatform
  accountId    String     @map("account_id")
  campaignId   String     @map("campaign_id")
  campaignName String     @map("campaign_name")
  status       String?
  date         DateTime   @db.Date
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  spend        Decimal    @default(0) @db.Decimal(12, 2)
  reach        Int        @default(0)
  cpm          Decimal    @default(0) @db.Decimal(10, 4)
  ctr          Decimal    @default(0) @db.Decimal(10, 4)
  roas         Decimal    @default(0) @db.Decimal(10, 4)
  conversions  Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([platform, campaignId, date])
  @@map("campaign_metrics")
}

model Ga4Metric {
  id         String   @id @default(uuid())
  date       DateTime @db.Date
  sessions   Int      @default(0)
  users      Int      @default(0)
  pageviews  Int      @default(0)
  bounceRate Decimal  @default(0) @db.Decimal(10, 4) @map("bounce_rate")
  source     String?
  medium     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([date, source, medium])
  @@map("ga4_metrics")
}

model MerchantProduct {
  id             String   @id @default(uuid())
  externalId     String   @unique @map("external_id")
  title          String
  status         String
  issues         Json?
  clicks         Int      @default(0)
  impressions    Int      @default(0)
  syncedAt       DateTime @default(now()) @map("synced_at")

  @@map("merchant_products")
}

// ============================================================
// ALERTAS
// ============================================================

enum AlertOperator {
  gt
  lt
  eq
}

model Alert {
  id          String        @id @default(uuid())
  name        String
  platform    String
  metric      String
  operator    AlertOperator
  threshold   Decimal       @db.Decimal(12, 4)
  active      Boolean       @default(true)
  notifiedAt  DateTime?     @map("notified_at")
  createdBy   String        @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  creator       User                @relation("CreatedBy", fields: [createdBy], references: [id])
  notifications AlertNotification[]

  @@map("alerts")
}

model AlertNotification {
  id        String    @id @default(uuid())
  alertId   String?   @map("alert_id") // null = notificação de sistema (ex.: nova avaliação)
  message   String
  link      String? // destino ao clicar (default: alertas de campanha)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  alert Alert? @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@map("alert_notifications")
}

// ============================================================
// PEDIDOS (WBUY)
// ============================================================

model Order {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  externalId String   @unique @map("external_id")
  platform   String   @default("wbuy")
  status     String
  total      Decimal  @db.Decimal(12, 2)
  items      Json?
  createdAt  DateTime @default(now()) @map("created_at")
  syncedAt   DateTime @default(now()) @map("synced_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@map("orders")
}

// ============================================================
// AUTOMAÇÕES
// ============================================================

model Automation {
  id            String   @id @default(uuid())
  name          String
  active        Boolean  @default(false)
  triggerType   String   @map("trigger_type")
  triggerConfig Json     @map("trigger_config")
  n8nWorkflowId String?  @map("n8n_workflow_id")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creator User       @relation("CreatedBy", fields: [createdBy], references: [id])
  actions AutomationAction[]

  @@map("automations")
}

model AutomationAction {
  id           String @id @default(uuid())
  automationId String @map("automation_id")
  position     Int
  actionType   String @map("action_type")
  actionConfig Json   @map("action_config")

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@map("automation_actions")
}

// ============================================================
// COMENTÁRIOS DE POSTS (INSTAGRAM)
// ============================================================

model PostComment {
  id            String    @id @default(uuid())
  postId        String    @map("post_id")
  postCaption   String?   @map("post_caption")
  postMediaUrl  String?   @map("post_media_url")
  commentId     String    @unique @map("comment_id")
  authorName    String    @map("author_name")
  authorId      String    @map("author_id")
  content       String
  repliedAt     DateTime? @map("replied_at")
  replyContent  String?   @map("reply_content")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("post_comments")
}
