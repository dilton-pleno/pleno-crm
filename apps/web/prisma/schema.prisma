generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICAÇÃO
// ============================================================

enum Role {
  ADMIN
  GESTOR
  ATENDENTE
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(ATENDENTE)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  assignedConversations Conversation[] @relation("AssignedTo")
  sentMessages          Message[]      @relation("SentBy")
  pipelineCards         PipelineCard[] @relation("CardAssignedTo")
  pipelines             Pipeline[]     @relation("CreatedBy")
  alerts                Alert[]        @relation("CreatedBy")
  automations           Automation[]   @relation("CreatedBy")
  quickReplies          QuickReply[]   @relation("QuickReplyCreator")
  contactNotes          ContactNote[]  @relation("ContactNoteAuthor")

  integrationRequestsMade     IntegrationRequest[] @relation("RequestedBy")
  integrationRequestsApproved IntegrationRequest[] @relation("ApprovedBy")

  teamMemberships TeamMember[]

  @@map("users")
}

// ============================================================
// TIMES (SETORES) — agrupam usuários e dão acesso a Canais/Pipelines
// ============================================================

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  members   TeamMember[]
  inboxes   TeamInbox[]
  pipelines TeamPipeline[] // pipeline pode ser compartilhado entre times (m2m)

  @@map("teams")
}

model TeamMember {
  teamId    String  @map("team_id")
  userId    String  @map("user_id")
  isManager Boolean @default(false) @map("is_manager") // Gestor do time

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamInbox {
  teamId  String @map("team_id")
  inboxId String @map("inbox_id")

  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inbox Inbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  @@id([teamId, inboxId])
  @@index([inboxId])
  @@map("team_inboxes")
}

model TeamPipeline {
  teamId     String @map("team_id")
  pipelineId String @map("pipeline_id")

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@id([teamId, pipelineId])
  @@index([pipelineId])
  @@map("team_pipelines")
}

model IntegrationRequest {
  id          String   @id @default(uuid())
  type        String // "whatsapp_reconnect"
  requestedBy String   @map("requested_by")
  approvedBy  String?  @map("approved_by")
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requester User  @relation("RequestedBy", fields: [requestedBy], references: [id])
  approver  User? @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@map("integration_requests")
}

// Configuração de integrações externas gerenciadas pelo painel (ex.: Wbuy).
// O segredo da API é guardado cifrado (AES-256-GCM) em apiSecret.
model IntegrationConfig {
  id         String   @id @default(uuid())
  provider   String   @unique // "wbuy"
  apiUser    String?  @map("api_user")
  apiSecret  String?  @map("api_secret") // cifrado
  active     Boolean  @default(false)
  config     Json? // metadados (ex.: webhooks registrados)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("integration_configs")
}

// Carrinhos abandonados recebidos via webhook da Wbuy (não há GET na API, logo
// só há dados a partir do recebimento — sem backfill). Base para relatório.
model AbandonedCart {
  id            String   @id @default(uuid())
  externalId    String   @map("external_id") // id_envio
  storeIntegrationId String? @map("store_integration_id") // loja (Integration ecommerce)
  customerName  String?  @map("customer_name")
  customerEmail String?  @map("customer_email")
  customerPhone String?  @map("customer_phone")
  total         Decimal  @default(0) @db.Decimal(12, 2)
  itemsCount    Int      @default(0) @map("items_count")
  products      Json?
  recovered     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  store Integration? @relation("StoreCarts", fields: [storeIntegrationId], references: [id], onDelete: Restrict)

  @@unique([storeIntegrationId, externalId])
  @@index([storeIntegrationId])
  @@map("abandoned_carts")
}

// Produtos ATIVOS da Wbuy (catálogo enxuto p/ cruzar vendas por SKU + SEO).
model WbuyProduct {
  id          String   @id @default(uuid())
  externalId  String   @map("external_id") // id do produto na Wbuy
  storeIntegrationId String? @map("store_integration_id")
  cod         String?
  name        String
  description String?  @db.Text
  brand       String?
  category    String?
  categoryUrl String?  @map("category_url")
  gtin        String?
  ncm         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  stock       Int      @default(0)
  views       Int      @default(0)
  active      Boolean  @default(true)
  syncedAt    DateTime @default(now()) @map("synced_at")

  store Integration? @relation("StoreProducts", fields: [storeIntegrationId], references: [id], onDelete: Restrict)

  @@unique([storeIntegrationId, externalId])
  @@index([storeIntegrationId])
  @@map("wbuy_products")
}

// Avaliações de produtos (Wbuy não tem webhook de avaliação → polling).
model WbuyReview {
  id           String    @id @default(uuid())
  externalId   String    @map("external_id")
  storeIntegrationId String? @map("store_integration_id")
  productId    String?   @map("product_id")
  productName  String?   @map("product_name")
  customerName String?   @map("customer_name")
  rating       Int       @default(0)
  comment      String?   @db.Text
  approved     Boolean   @default(false)
  reviewDate   DateTime? @map("review_date")
  alertedAt    DateTime? @map("alerted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  store Integration? @relation("StoreReviews", fields: [storeIntegrationId], references: [id], onDelete: Restrict)

  @@unique([storeIntegrationId, externalId])
  @@index([storeIntegrationId])
  @@map("wbuy_reviews")
}

// Inscritos na newsletter da Wbuy (chave = email).
model NewsletterSubscriber {
  id         String    @id @default(uuid())
  email      String
  storeIntegrationId String? @map("store_integration_id")
  name       String?
  phone      String?
  gender     String?
  subscribed Boolean   @default(true)
  signupDate DateTime? @map("signup_date")
  syncedAt   DateTime  @default(now()) @map("synced_at")

  store Integration? @relation("StoreNewsletter", fields: [storeIntegrationId], references: [id], onDelete: Restrict)

  @@unique([storeIntegrationId, email])
  @@index([storeIntegrationId])
  @@map("newsletter_subscribers")
}

// ============================================================
// CANAIS (INBOXES) — uma "caixa"/conta de atendimento por setor.
// Cada Canal agrupa, no máximo, 1 WhatsApp + 1 Instagram + 1 Facebook
// próprios, com credenciais por Canal (preenchidas a partir da Fase 3).
// Não confundir com ContactChannel (handle do contato) nem com ChannelType.
// ============================================================

model Inbox {
  id     String  @id @default(uuid())
  name   String // ex.: "Canal XPTO" — rótulo na UI: "Canal"
  active Boolean @default(true)
  // WhatsApp — provider por Canal: "evolution" (API não oficial) ou "cloud"
  // (API oficial Meta Cloud). Default evolution mantém o comportamento atual.
  whatsappProvider String @default("evolution") @map("whatsapp_provider")
  // Evolution: instância própria (a API key é global da Evolution).
  whatsappInstance String? @map("whatsapp_instance")
  // Cloud API (oficial): phone_number_id roteia o webhook; token/WABA/verify
  // cifrados em whatsappConfig.
  whatsappPhoneNumberId String? @map("whatsapp_phone_number_id")
  whatsappConfig        Json?   @map("whatsapp_config") // accessTokenEnc, wabaId, verifyTokenEnc (cifrados)
  // Meta mensageria por Canal: page/IG + token/verify cifrados em metaConfig.
  metaPageId String? @map("meta_page_id")
  metaIgId   String? @map("meta_ig_id")
  metaConfig Json?   @map("meta_config") // accessTokenEnc, verifyTokenEnc (cifrados)
  // Integrações reutilizáveis (novo modelo): o Canal SELECIONA uma integração de
  // WhatsApp e uma de Meta. @unique garante a exclusividade 1:1 (uma integração
  // usada num Canal não pode ser usada em outro). As colunas acima ficam como
  // fallback durante a transição.
  whatsappIntegrationId String? @unique @map("whatsapp_integration_id")
  metaIntegrationId     String? @unique @map("meta_integration_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  whatsappIntegration Integration? @relation("InboxWhatsapp", fields: [whatsappIntegrationId], references: [id])
  metaIntegration     Integration? @relation("InboxMeta",     fields: [metaIntegrationId],     references: [id])
  conversations Conversation[]
  channels      ContactChannel[]
  postComments  PostComment[]
  teams         TeamInbox[]

  @@map("inboxes")
}

// Integração externa como INSTÂNCIA nomeada e reutilizável (vários WhatsApp,
// várias contas Meta). Criada em Integrações e atribuída a um Canal (1:1 via
// Inbox.*IntegrationId @unique). Identificadores de roteamento ficam em colunas
// indexadas; segredos ficam cifrados (AES-256-GCM) em config.
model Integration {
  id       String  @id @default(uuid())
  type     String // "whatsapp" | "meta" | "ecommerce"
  name     String // rótulo, ex.: "Atendimento", "Comercial", "Loja principal"
  provider String? // whatsapp: "evolution" | "cloud"; meta/ecommerce: null
  platform String? // ecommerce: "wbuy" | (futuro) "nuvemshop"
  active   Boolean @default(true)
  // Roteamento (não-segredo, indexado):
  waInstance      String? @map("wa_instance") // Evolution
  waPhoneNumberId String? @map("wa_phone_number_id") // Cloud
  metaPageId      String? @map("meta_page_id")
  metaIgId        String? @map("meta_ig_id")
  config    Json? // segredos cifrados: accessTokenEnc/wabaId/verifyTokenEnc (msg) ou apiUser/apiSecretEnc/webhookSecretEnc (ecommerce)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inboxWhatsapp Inbox? @relation("InboxWhatsapp")
  inboxMeta     Inbox? @relation("InboxMeta")
  // Dados de e-commerce escopados a esta loja (quando type = "ecommerce").
  orders                Order[]                @relation("StoreOrders")
  wbuyProducts          WbuyProduct[]          @relation("StoreProducts")
  wbuyReviews           WbuyReview[]           @relation("StoreReviews")
  newsletterSubscribers NewsletterSubscriber[] @relation("StoreNewsletter")
  abandonedCarts        AbandonedCart[]        @relation("StoreCarts")

  @@index([type])
  @@index([waInstance])
  @@index([waPhoneNumberId])
  @@index([metaPageId])
  @@index([metaIgId])
  @@map("integrations")
}

// ============================================================
// CONTATOS E CANAIS
// ============================================================

enum ChannelType {
  whatsapp
  instagram
  messenger
  email
  site
}

model Contact {
  id             String    @id @default(uuid())
  name           String
  email          String?
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  notes          String?
  organizationId String?   @map("organization_id")
  // Dados enriquecidos da Wbuy (clientes / pedidos)
  document       String?   @map("document")           // doc1 (CPF/CNPJ)
  document2      String?   @map("document2")           // doc2 (RG/IE)
  birthDate      DateTime? @map("birth_date")
  gender         String?
  city           String?
  uf             String?
  secondaryPhone String?   @map("secondary_phone")     // telefone2
  addresses      Json?                                 // lista de enderecos da Wbuy
  wbuyCustomerId String?   @map("wbuy_customer_id")
  instagramHandle String?  @map("instagram_handle")    // @ do IG (sem "@", minusculo) p/ cruzar contatos
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  channels      ContactChannel[]
  conversations Conversation[]
  cards         PipelineCard[]
  orders        Order[]
  tags          Tag[]
  internalNotes ContactNote[]

  @@index([instagramHandle])
  @@map("contacts")
}

model ContactNote {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author  User    @relation("ContactNoteAuthor", fields: [authorId], references: [id])

  @@index([contactId])
  @@map("contact_notes")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now()) @map("created_at")

  contacts Contact[]

  @@map("tags")
}

model QuickReply {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  shared    Boolean  @default(false)
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator User @relation("QuickReplyCreator", fields: [createdBy], references: [id])

  @@map("quick_replies")
}

model ContactChannel {
  id                String      @id @default(uuid())
  contactId         String      @map("contact_id")
  channelType       ChannelType @map("channel_type")
  channelIdentifier String      @map("channel_identifier")
  inboxId           String?     @map("inbox_id") // de qual Canal aquele handle veio
  metadata          Json?
  createdAt         DateTime    @default(now()) @map("created_at")

  contact       Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  inbox         Inbox?         @relation(fields: [inboxId], references: [id])
  conversations Conversation[]

  @@unique([channelType, channelIdentifier])
  @@index([inboxId])
  @@map("contact_channels")
}

// ============================================================
// CONVERSAS E MENSAGENS
// ============================================================

enum ConversationStatus {
  open
  pending
  resolved
}

model Conversation {
  id         String             @id @default(uuid())
  contactId  String             @map("contact_id")
  channelId  String             @map("channel_id")
  inboxId    String?            @map("inbox_id") // Canal que originou a conversa
  status     ConversationStatus @default(open)
  assignedTo String?            @map("assigned_to")
  inboxName  String?            @map("inbox_name")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  contact  Contact        @relation(fields: [contactId], references: [id])
  channel  ContactChannel @relation(fields: [channelId], references: [id])
  inbox    Inbox?         @relation(fields: [inboxId], references: [id])
  agent    User?          @relation("AssignedTo", fields: [assignedTo], references: [id])
  messages Message[]
  cards    PipelineCard[]

  @@index([inboxId])
  @@map("conversations")
}

enum MessageDirection {
  in
  out
}

enum MediaType {
  image
  audio
  document
  sticker
  video
}

model Message {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  direction      MessageDirection
  content        String?
  mediaUrl       String?          @map("media_url")
  mediaType      MediaType?       @map("media_type")
  mediaData      Bytes?           @map("media_data")
  mediaMimeType  String?          @map("media_mime_type")
  mediaFileName  String?          @map("media_file_name")
  externalId     String?          @map("external_id")
  senderId       String?          @map("sender_id")
  sentAt         DateTime         @default(now()) @map("sent_at")
  deliveredAt    DateTime?        @map("delivered_at")
  readAt         DateTime?        @map("read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("SentBy", fields: [senderId], references: [id])

  @@map("messages")
}

// ============================================================
// KANBAN
// ============================================================

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator User            @relation("CreatedBy", fields: [createdBy], references: [id])
  stages  PipelineStage[]
  teams   TeamPipeline[]

  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String   @map("pipeline_id")
  name       String
  position   Int
  color      String   @default("#6366f1")
  createdAt  DateTime @default(now()) @map("created_at")

  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  cards    PipelineCard[]

  @@map("pipeline_stages")
}

model PipelineCard {
  id             String   @id @default(uuid())
  stageId        String   @map("stage_id")
  conversationId String   @map("conversation_id")
  contactId      String   @map("contact_id")
  assignedTo     String?  @map("assigned_to")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  stage        PipelineStage @relation(fields: [stageId], references: [id])
  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id])
  agent        User?         @relation("CardAssignedTo", fields: [assignedTo], references: [id])

  @@map("pipeline_cards")
}

// ============================================================
// CAMPANHAS E ANALYTICS
// ============================================================

enum AdPlatform {
  meta
  google
}

model CampaignMetric {
  id           String     @id @default(uuid())
  platform     AdPlatform
  accountId    String     @map("account_id")
  campaignId   String     @map("campaign_id")
  campaignName String     @map("campaign_name")
  status       String?
  date         DateTime   @db.Date
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  spend        Decimal    @default(0) @db.Decimal(12, 2)
  reach        Int        @default(0)
  cpm          Decimal    @default(0) @db.Decimal(10, 4)
  ctr          Decimal    @default(0) @db.Decimal(10, 4)
  roas         Decimal    @default(0) @db.Decimal(10, 4)
  conversions  Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([platform, campaignId, date])
  @@map("campaign_metrics")
}

model Ga4Metric {
  id         String   @id @default(uuid())
  date       DateTime @db.Date
  sessions   Int      @default(0)
  users      Int      @default(0)
  pageviews  Int      @default(0)
  bounceRate Decimal  @default(0) @db.Decimal(10, 4) @map("bounce_rate")
  source     String?
  medium     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([date, source, medium])
  @@map("ga4_metrics")
}

model MerchantProduct {
  id             String   @id @default(uuid())
  externalId     String   @unique @map("external_id")
  title          String
  status         String
  issues         Json?
  clicks         Int      @default(0)
  impressions    Int      @default(0)
  syncedAt       DateTime @default(now()) @map("synced_at")

  @@map("merchant_products")
}

// ============================================================
// ALERTAS
// ============================================================

enum AlertOperator {
  gt
  lt
  eq
}

model Alert {
  id          String        @id @default(uuid())
  name        String
  platform    String
  metric      String
  operator    AlertOperator
  threshold   Decimal       @db.Decimal(12, 4)
  active      Boolean       @default(true)
  notifiedAt  DateTime?     @map("notified_at")
  createdBy   String        @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  creator       User                @relation("CreatedBy", fields: [createdBy], references: [id])
  notifications AlertNotification[]

  @@map("alerts")
}

model AlertNotification {
  id        String    @id @default(uuid())
  alertId   String?   @map("alert_id") // null = notificação de sistema (ex.: nova avaliação)
  message   String
  link      String? // destino ao clicar (default: alertas de campanha)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  alert Alert? @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@map("alert_notifications")
}

// ============================================================
// PEDIDOS (WBUY)
// ============================================================

model Order {
  id          String   @id @default(uuid())
  contactId   String   @map("contact_id")
  externalId  String   @map("external_id")
  storeIntegrationId String? @map("store_integration_id") // loja (Integration ecommerce)
  platform    String   @default("wbuy")
  status      String
  total       Decimal  @db.Decimal(12, 2)
  items       Json?
  tracking    String?  // codigo de rastreio (frete.rastreio)
  carrier     String?  // transportadora (frete.nome)
  trackingUrl String?  @map("tracking_url")
  createdAt   DateTime @default(now()) @map("created_at")
  syncedAt    DateTime @default(now()) @map("synced_at")

  contact Contact     @relation(fields: [contactId], references: [id])
  store   Integration? @relation("StoreOrders", fields: [storeIntegrationId], references: [id], onDelete: Restrict)

  @@unique([storeIntegrationId, externalId])
  @@index([storeIntegrationId])
  @@map("orders")
}

// ============================================================
// AUTOMAÇÕES
// ============================================================

model Automation {
  id            String   @id @default(uuid())
  name          String
  active        Boolean  @default(false)
  triggerType   String   @map("trigger_type")
  triggerConfig Json     @map("trigger_config")
  n8nWorkflowId String?  @map("n8n_workflow_id")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creator User       @relation("CreatedBy", fields: [createdBy], references: [id])
  actions AutomationAction[]
  runs    AutomationRun[]

  @@map("automations")
}

enum AutomationRunStatus {
  running
  waiting
  done
  error
}

// Registro de cada disparo de automação: observabilidade (log) e base para a
// ação `wait` (status waiting + resumeAt, retomado por cron na Fase 3).
model AutomationRun {
  id              String              @id @default(uuid())
  automationId    String              @map("automation_id")
  conversationId  String?             @map("conversation_id")
  contactId       String?             @map("contact_id")
  trigger         String // tipo de gatilho que disparou
  status          AutomationRunStatus @default(running)
  currentPosition Int                 @default(0) @map("current_position")
  resumeAt        DateTime?           @map("resume_at")
  context         Json?
  error           String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([status, resumeAt])
  @@map("automation_runs")
}

model AutomationAction {
  id           String @id @default(uuid())
  automationId String @map("automation_id")
  position     Int
  actionType   String @map("action_type")
  actionConfig Json   @map("action_config")

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@map("automation_actions")
}

// ============================================================
// COMENTÁRIOS DE POSTS (INSTAGRAM)
// ============================================================

model PostComment {
  id            String    @id @default(uuid())
  postId        String    @map("post_id")
  postCaption   String?   @map("post_caption")
  postMediaUrl  String?   @map("post_media_url")
  commentId     String    @unique @map("comment_id")
  authorName    String    @map("author_name")
  authorId      String    @map("author_id")
  content       String
  platform      String?   // "instagram" | "facebook"
  inboxId       String?   @map("inbox_id") // Canal (página IG/FB) de origem
  repliedAt     DateTime? @map("replied_at")
  replyContent  String?   @map("reply_content")
  createdAt     DateTime  @default(now()) @map("created_at")

  inbox Inbox? @relation(fields: [inboxId], references: [id])

  @@index([inboxId])
  @@map("post_comments")
}
