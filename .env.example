# =============================================================================
# PLENO CRM - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com os valores corretos
# NUNCA commit o .env.local no repositório
# =============================================================================

# =============================================================================
# BANCO DE DADOS
# Local:      postgresql://admin:pleno_dev_2026@localhost:5432/pleno_crm_dev
# Produção:   configurado no Coolify
# =============================================================================
DATABASE_URL=postgresql://admin:pleno_dev_2026@localhost:5432/pleno_crm_dev

# =============================================================================
# NEXTAUTH
# Gerar NEXTAUTH_SECRET com: openssl rand -hex 32
# =============================================================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# GOOGLE OAUTH
# Criar em: https://console.cloud.google.com/
# Necessário para GA4 e Google Ads (Módulo 4)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# EVOLUTION API
# URL local para desenvolvimento apontando para VPS via tunnel ou direto
# =============================================================================
EVOLUTION_API_URL=https://evo.meucuidadoessencial.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=atendimento

# =============================================================================
# CHATWOOT (gateway de mensagens)
# =============================================================================
CHATWOOT_URL=https://chatwoot.meucuidadoessencial.com.br
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# =============================================================================
# META (Instagram, Messenger, Meta Ads)
# Configurar no Módulo 2 e Módulo 4
# =============================================================================
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_WEBHOOK_VERIFY_TOKEN=pleno_crm_webhook_2026

# =============================================================================
# GOOGLE ADS
# Configurar no Módulo 4
# =============================================================================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# =============================================================================
# GOOGLE ANALYTICS 4
# Configurar no Módulo 4
# =============================================================================
GA4_PROPERTY_ID=

# =============================================================================
# GOOGLE MERCHANT CENTER
# Configurar no Módulo 4
# =============================================================================
MERCHANT_CENTER_ID=

# =============================================================================
# N8N
# Secret para autenticar chamadas internas do N8N para o Pleno CRM
# =============================================================================
N8N_WEBHOOK_SECRET=
N8N_API_URL=https://n8n.meucuidadoessencial.com.br
N8N_API_KEY=

# =============================================================================
# WBUY
# Configurar no Módulo 5
# =============================================================================
WBUY_API_URL=
WBUY_API_KEY=

# =============================================================================
# REDIS
# Local:    redis://localhost:6379/4
# Produção: configurado no Coolify
# =============================================================================
REDIS_URL=redis://localhost:6379/4

# =============================================================================
# INTERNAL SECRETS
# Secrets para endpoints internos chamados pelo N8N
# Gerar com: openssl rand -hex 32
# =============================================================================
INTERNAL_API_SECRET=
